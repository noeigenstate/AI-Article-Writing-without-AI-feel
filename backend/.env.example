# ── Cloud model (default) ─────────────────────────────────────────────
# Any OpenAI-compatible endpoint works. DeepSeek shown as the default.
DEEPSEEK_API_KEY=your_deepseek_api_key
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-v4-pro
LLM_THINKING_TYPE=enabled
LLM_REASONING_EFFORT=high
LLM_TEMPERATURE=0.7
PORT=8787

# ── Private / local model (optional) ──────────────────────────────────
# Run everything on your own machine — text never leaves it.
# Point at Ollama / LM Studio / vLLM (any OpenAI-compatible server) and
# turn OFF the reasoning extras, which local servers usually reject.
#
# LLM_BASE_URL=http://localhost:11434/v1   # Ollama
# LLM_API_KEY=ollama                        # any non-empty string
# LLM_MODEL=qwen2.5:14b
# LLM_THINKING_TYPE=off
# LLM_REASONING_EFFORT=off
#
# Note: the AI-smell score is always 100% local — it never calls a model.
